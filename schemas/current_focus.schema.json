{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "current_focus.schema.json",
  "title": "AMAI Current Focus Schema",
  "description": "Validates goals/current_focus.yaml",
  "type": "object",
  "required": ["week_of", "last_updated", "priorities", "not_this_week", "the_one_thing"],
  "properties": {
    "_schema": {
      "type": "string",
      "const": "current_focus"
    },
    "_version": {
      "type": "string",
      "const": "1.0"
    },
    "_description": {
      "type": "string"
    },
    "week_of": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "last_updated": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "priorities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["rank", "item", "goal_ref"],
        "properties": {
          "rank": {
            "type": "integer",
            "minimum": 1
          },
          "item": {
            "type": "string",
            "minLength": 5
          },
          "goal_ref": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "why_now": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "not_this_week": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "the_one_thing": {
      "type": "string",
      "minLength": 5
    }
  },
  "additionalProperties": false
}
