{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rhythms.schema.json",
  "title": "AMAI Network Rhythms Schema",
  "description": "Validates network/rhythms.yaml",
  "type": "object",
  "required": ["_schema", "rhythms", "last_updated"],
  "properties": {
    "_schema": {
      "type": "string",
      "const": "rhythms"
    },
    "_version": {
      "type": "string",
      "const": "1.0"
    },
    "_description": {
      "type": "string"
    },
    "rhythms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["circle", "label", "target_frequency", "max_gap", "touchpoint_types"],
        "properties": {
          "circle": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "target_frequency": {
            "type": "string",
            "minLength": 1
          },
          "max_gap": {
            "oneOf": [
              { "type": "string" },
              { "type": "null" }
            ]
          },
          "touchpoint_types": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "last_updated": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false
}
