{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "failures.schema.json",
  "title": "AMAI Failure Entry Schema",
  "description": "Validates each line of memory/failures.jsonl",
  "type": "object",
  "required": [
    "date",
    "what_failed",
    "context",
    "what_i_did",
    "what_went_wrong",
    "warning_signs_missed",
    "what_id_do_differently",
    "emotional_weight",
    "lesson"
  ],
  "properties": {
    "_example": {
      "type": "boolean"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "what_failed": {
      "type": "string",
      "minLength": 1
    },
    "context": {
      "type": "string",
      "minLength": 1
    },
    "what_i_did": {
      "type": "string",
      "minLength": 1
    },
    "what_went_wrong": {
      "type": "string",
      "minLength": 1
    },
    "warning_signs_missed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "what_id_do_differently": {
      "type": "string",
      "minLength": 1
    },
    "emotional_weight": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "lesson": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
