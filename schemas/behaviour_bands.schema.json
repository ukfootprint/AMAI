{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AMAI Behaviour Bands",
  "description": "Schema for org/overlays/[org]/behaviour_bands.yaml — per-org behaviour band definitions",
  "type": "object",
  "required": ["_schema", "bands"],
  "properties": {
    "_schema": { "type": "string", "const": "behaviour_bands" },
    "_version": { "type": "string" },
    "_description": { "type": "string" },
    "last_updated": { "type": ["string", "null"] },
    "bands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "personal_default", "org_range", "applies_to"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "description": "snake_case identifier for this band"
          },
          "personal_default": {
            "type": "string",
            "minLength": 5,
            "description": "The user's default behaviour in personal context"
          },
          "org_range": {
            "type": "string",
            "minLength": 5,
            "description": "How this band should be adjusted for the org context"
          },
          "applies_to": {
            "type": "string",
            "minLength": 5,
            "description": "Which tasks or situations this band covers"
          },
          "notes": {
            "type": "string",
            "description": "Optional free-text notes"
          }
        }
      }
    }
  },
  "additionalProperties": false
}
