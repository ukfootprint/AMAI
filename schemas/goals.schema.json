{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "goals.schema.json",
  "title": "AMAI Goals Schema",
  "description": "Validates goals/goals.yaml",
  "type": "object",
  "required": ["_schema", "_version", "goals", "last_updated"],
  "properties": {
    "_schema": {
      "type": "string",
      "const": "goals"
    },
    "_version": {
      "type": "string",
      "const": "1.0"
    },
    "_description": {
      "type": "string"
    },
    "goals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "status", "horizon", "why", "key_results"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["active", "on_hold", "completed", "abandoned"]
          },
          "horizon": {
            "type": "string",
            "minLength": 1
          },
          "why": {
            "type": "string",
            "minLength": 1
          },
          "key_results": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "last_updated": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false
}
