{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "observations.schema.json",
  "title": "AMAI Observation Entry Schema",
  "description": "Validates each line of signals/observations.jsonl",
  "type": "object",
  "required": ["date", "context", "signals"],
  "properties": {
    "_example": {
      "type": "boolean"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "context": {
      "type": "string",
      "minLength": 1
    },
    "signals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "possible_divergence": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "config_ref": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "reviewed": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false
}
