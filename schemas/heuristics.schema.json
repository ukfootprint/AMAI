{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "heuristics.schema.json",
  "title": "AMAI Heuristics Schema",
  "description": "Validates identity/heuristics.yaml",
  "type": "object",
  "required": ["_schema", "_version", "universal", "last_updated"],
  "properties": {
    "_schema": {
      "type": "string",
      "const": "heuristics"
    },
    "_version": {
      "type": "string",
      "const": "1.0"
    },
    "_description": {
      "type": "string"
    },
    "universal": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "rule", "use_when", "confidence"],
        "properties": {
          "id": {
            "type": "string"
          },
          "rule": {
            "type": "string",
            "minLength": 1
          },
          "use_when": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string"
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          }
        },
        "additionalProperties": false
      }
    },
    "domain": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "rule", "confidence"],
        "properties": {
          "id": {
            "type": "string"
          },
          "rule": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string"
          },
          "use_when": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          }
        },
        "additionalProperties": false
      }
    },
    "commercial": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "rule", "confidence"],
        "properties": {
          "id": {
            "type": "string"
          },
          "rule": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string"
          },
          "use_when": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          }
        },
        "additionalProperties": false
      }
    },
    "people": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "rule", "confidence"],
        "properties": {
          "id": {
            "type": "string"
          },
          "rule": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string"
          },
          "use_when": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          }
        },
        "additionalProperties": false
      }
    },
    "when_stuck": {
      "type": "object",
      "properties": {
        "steps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "last_updated": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false
}
