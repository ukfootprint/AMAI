{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "decisions.schema.json",
  "title": "AMAI Decision Entry Schema",
  "description": "Validates each line of memory/decisions.jsonl",
  "type": "object",
  "required": ["date", "decision", "context", "options_considered", "reasoning"],
  "properties": {
    "_example": {
      "type": "boolean"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "decision": {
      "type": "string",
      "minLength": 10
    },
    "context": {
      "type": "string",
      "minLength": 1
    },
    "options_considered": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "reasoning": {
      "type": "string",
      "minLength": 10
    },
    "values_applied": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outcome": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "would_decide_same": {
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
