{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "values.schema.json",
  "title": "AMAI Values Schema",
  "description": "Validates identity/values.yaml",
  "type": "object",
  "required": ["_schema", "_version", "core_values", "ethical_red_lines", "last_updated"],
  "properties": {
    "_schema": {
      "type": "string",
      "const": "values"
    },
    "_version": {
      "type": "string",
      "const": "1.0"
    },
    "_description": {
      "type": "string"
    },
    "core_values": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "priority", "description", "in_practice", "test"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "type": "integer",
            "minimum": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "in_practice": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "test": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "secondary_values": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "description"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "ethical_red_lines": {
      "type": "array",
      "minItems": 1,
      "description": "Accepts both legacy string format (deprecated) and structured When/Do/Never/Except objects. String format still validates but will produce WARN:DEPRECATED_RED_LINE_FORMAT. Migrate to structured format using docs/red_line_migration.md.",
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 10,
            "description": "Legacy string format — deprecated. Use structured object format instead."
          },
          {
            "type": "object",
            "required": ["id", "when", "never", "examples"],
            "properties": {
              "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
              "when": {"type": "string", "minLength": 10},
              "do": {"type": "string", "minLength": 10},
              "never": {"type": "string", "minLength": 10},
              "except": {"type": "string"},
              "examples": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "string", "minLength": 10}
              },
              "severity": {
                "type": "string",
                "enum": ["absolute", "strong"],
                "default": "absolute"
              }
            },
            "additionalProperties": false,
            "description": "Structured When/Do/Never/Except format — recommended."
          }
        ]
      }
    },
    "last_updated": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false
}
