{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "circles.schema.json",
  "title": "AMAI Network Circles Schema",
  "description": "Validates network/circles.yaml",
  "type": "object",
  "required": ["_schema", "circles", "last_updated"],
  "properties": {
    "_schema": {
      "type": "string",
      "const": "circles"
    },
    "_version": {
      "type": "string",
      "const": "1.0"
    },
    "_description": {
      "type": "string"
    },
    "circles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "description", "criteria", "touchpoint_type", "current_count"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "capacity": {
            "oneOf": [
              { "type": "integer", "minimum": 1 },
              { "type": "null" }
            ]
          },
          "touchpoint_type": {
            "type": "string",
            "enum": ["personal", "professional", "either"]
          },
          "current_count": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    },
    "movement_criteria": {
      "type": "object",
      "properties": {
        "promotion": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "demotion": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "last_updated": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false
}
