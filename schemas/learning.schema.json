{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "learning.schema.json",
  "title": "AMAI Learning Entry Schema",
  "description": "Validates each line of knowledge/learning.jsonl",
  "type": "object",
  "required": ["date", "type", "source", "insight", "context", "confidence"],
  "properties": {
    "_example": {
      "type": "boolean"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "type": {
      "type": "string",
      "enum": ["correction", "preference", "pattern", "insight"]
    },
    "source": {
      "type": "string",
      "enum": ["experience", "conversation", "reading", "observation"]
    },
    "insight": {
      "type": "string",
      "minLength": 10
    },
    "context": {
      "type": "string",
      "minLength": 1
    },
    "applies_to": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    }
  },
  "additionalProperties": false
}
