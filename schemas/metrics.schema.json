{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "metrics.schema.json",
  "title": "AMAI Calibration Metrics Schema",
  "description": "Validates calibration/metrics.yaml",
  "type": "object",
  "required": ["signal_volume", "divergence_volume", "module_load_frequency", "learning_log", "last_updated"],
  "properties": {
    "_schema": {
      "type": "string"
    },
    "_version": {
      "type": "string"
    },
    "_description": {
      "type": "string"
    },
    "signal_volume": {
      "type": "object",
      "required": ["total_observations", "by_type", "sessions_with_no_signal"],
      "properties": {
        "total_observations": {
          "type": "integer",
          "minimum": 0
        },
        "by_type": {
          "type": "object",
          "properties": {
            "override": { "type": "integer", "minimum": 0 },
            "friction": { "type": "integer", "minimum": 0 },
            "positive": { "type": "integer", "minimum": 0 },
            "pattern": { "type": "integer", "minimum": 0 },
            "inference": { "type": "integer", "minimum": 0 }
          }
        },
        "sessions_with_no_signal": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "divergence_volume": {
      "type": "object",
      "required": ["total_detected", "by_disposition", "pending_review_count"],
      "properties": {
        "total_detected": {
          "type": "integer",
          "minimum": 0
        },
        "by_disposition": {
          "type": "object",
          "properties": {
            "confirm": { "type": "integer", "minimum": 0 },
            "candidate": { "type": "integer", "minimum": 0 },
            "warning": { "type": "integer", "minimum": 0 },
            "defer": { "type": "integer", "minimum": 0 },
            "incorporated": { "type": "integer", "minimum": 0 },
            "rejected": { "type": "integer", "minimum": 0 }
          }
        },
        "pending_review_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "overrides_by_domain": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "module_load_frequency": {
      "type": "object",
      "required": ["identity", "goals", "knowledge", "network", "operations", "memory", "signals", "calibration"],
      "properties": {
        "identity": { "type": "integer", "minimum": 0 },
        "goals": { "type": "integer", "minimum": 0 },
        "knowledge": { "type": "integer", "minimum": 0 },
        "network": { "type": "integer", "minimum": 0 },
        "operations": { "type": "integer", "minimum": 0 },
        "memory": { "type": "integer", "minimum": 0 },
        "signals": { "type": "integer", "minimum": 0 },
        "calibration": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "learning_log": {
      "type": "object",
      "required": ["total_entries", "by_type"],
      "properties": {
        "total_entries": {
          "type": "integer",
          "minimum": 0
        },
        "by_type": {
          "type": "object",
          "properties": {
            "correction": { "type": "integer", "minimum": 0 },
            "preference": { "type": "integer", "minimum": 0 },
            "pattern": { "type": "integer", "minimum": 0 },
            "insight": { "type": "integer", "minimum": 0 }
          }
        }
      },
      "additionalProperties": false
    },
    "review_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "signals_reviewed"],
        "properties": {
          "date": {
            "oneOf": [
              { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
              { "type": "null" }
            ]
          },
          "signals_reviewed": {
            "type": "integer",
            "minimum": 0
          },
          "divergences_found": {
            "type": "integer",
            "minimum": 0
          },
          "incorporated": {
            "type": "integer",
            "minimum": 0
          },
          "rejected": {
            "type": "integer",
            "minimum": 0
          },
          "deferred": {
            "type": "integer",
            "minimum": 0
          },
          "health_note": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "last_updated": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false
}
