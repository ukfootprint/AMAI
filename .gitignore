# ─────────────────────────────────────────────
# AMAI — Personal Data Protection
# ─────────────────────────────────────────────
# These files contain private information.
# They are ignored by default to prevent accidental public commits.
# If you want to version-control your personal data (e.g. in a private repo),
# remove the relevant lines below.

# Network — relationship records are private
network/contacts.jsonl
network/organisations.jsonl
network/interactions.jsonl

# Memory — personal history is private
memory/experiences.jsonl
memory/decisions.jsonl
memory/failures.jsonl

# Signals — raw session observations are private
signals/observations.jsonl

# Calibration — divergence log may contain personal reflections
calibration/divergence.jsonl

# Evaluation results — scored outputs contain personal context
# Keep evaluation/results/ tracked in a private repo; exclude from public
evaluation/results/no_amai_baseline.md
evaluation/results/with_amai_*.md
evaluation/results/scores_*.md

# Org export bundles — never commit
EXPORT/

# Org tension logs contain personal data — exclude from public repos by default
org/overlays/*/tension_log.jsonl

# ─────────────────────────────────────────────
# OS & Editor files
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
